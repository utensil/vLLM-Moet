+    }
+
+    // ── Stage 2 QK ────────────────────────────────────────────""",
+)
+
+# ------------------------------------------------- 5. decode dsv3_2 dispatch
+DECCU = CSRC / "sparse_mla_sm120_decode_dsv3_2.cu"
+patch(
+    DECCU,
+    """    if (mt == ModelType::DSV3_2) {                 \\
